# Flask
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=cambia_esto_por_un_valor_largo_y_seguro

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Database (opcion 1)
DB_HOST=mysql
DB_PORT=3306
DB_USER=cellstore_user
DB_PASSWORD=root
DB_NAME=cellstore

# Database URL (opcion 2 - prioritaria)
# mysql+pymysql://usuario:password@host:3306/base_datos
DATABASE_URL=

# Uploads
MAX_UPLOAD_SIZE_MB=5
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif
UPLOAD_FOLDER=app_new/static/uploads

# Timezone
TIMEZONE=America/Bogota
