# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=tu_clave_secreta_cambia_esto_en_produccion

# Server Configuration
HOST=0.0.0.0
PORT=5000
DEBUG=False

# Database Configuration
